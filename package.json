{
  "name": "codemem",
  "version": "1.0.0",
  "description": "A VSCode/Cursor extension that acts as a \"Long-Term Pair Programmer\". As you code, it quietly observes and extracts EventLog Memory (architectural decisions, bug fixes) and Profile Memory (your preferred coding style). When you ask it a question, it uses EverMemOS to retrieve project-specific context that standard LLMs forget.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "web": "tsx src/web-server.ts",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangshi0512/CodeMem.git"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/zhangshi0512/CodeMem/issues"
  },
  "homepage": "https://github.com/zhangshi0512/CodeMem#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
